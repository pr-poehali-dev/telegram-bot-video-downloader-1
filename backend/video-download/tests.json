{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Missing URL returns 400",
      "method": "POST",
      "path": "/",
      "body": {},
      "expectedStatus": 400,
      "expectedBody": {"error": "URL обязателен"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Valid YouTube URL returns download link",
      "method": "POST",
      "path": "/",
      "body": {"url": "https://www.youtube.com/watch?v=jfKfPfyJRdk", "format": "MP4", "quality": "360p"},
      "expectedStatus": 200,
      "expectedBody": {"download_url": "string", "filename": "string"},
      "bodyMatcher": "partial"
    }
  ]
}
